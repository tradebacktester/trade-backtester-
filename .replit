modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 24593
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_ID = "7302782010"
ADMIN_PASSWORD = "adivasutrade"
GEMINI_API_KEY = "AQ.Ab8RN6IwjHI6T7LDd2vHP5h8GXAbW8a4WFf5DIFFd0U6ol7Jjg"
