# ── Railway Backend Environment Variables ─────────────────────────────────────
#
# Set all of these in Railway → your service → Variables tab.
# Never commit actual values to git.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway provides this automatically when you
# add a Postgres plugin: ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string for signing JWTs — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Groq API key — https://console.groq.com
GROQ_API_KEY=

# Admin credentials (dual-admin login required)
ADMIN_ID=
ADMIN_PASSWORD=
ADMIN_ID_2=
ADMIN_PASSWORD_2=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://trade-lab.vercel.app,https://my-custom-domain.com
# Leave empty to allow all origins (dev only — do NOT do this in production).
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Server port — Railway sets this automatically via $PORT
PORT=8080

# Node environment
NODE_ENV=production

# Razorpay (only needed if you use the subscription/payment features)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
