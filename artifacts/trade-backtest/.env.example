# ── Vercel Frontend Environment Variables ─────────────────────────────────────
#
# Copy this file to .env.local for local development.
# On Vercel: add these under Project → Settings → Environment Variables.

# Your Railway backend URL — no trailing slash.
# Leave empty when running locally (Vite proxies /api to the same Express server).
# Example: https://trade-lab-api.up.railway.app
VITE_API_URL=
