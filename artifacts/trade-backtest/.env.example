# ── Vercel Frontend Environment Variables ─────────────────────────────────────
#
# Copy to .env.local for local Vite dev (optional — proxy already handles /api).
# On Vercel: Project → Settings → Environment Variables → add each key below.

# Your Railway backend URL — no trailing slash.
# Leave empty when running locally (Vite dev server proxies /api automatically).
# Example: https://trade-lab-api.up.railway.app
VITE_API_BASE_URL=
