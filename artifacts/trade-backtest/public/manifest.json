{
  "id": "/",
  "name": "Trade Lab",
  "short_name": "Trade Lab",
  "description": "Professional trading platform with live charts, strategy backtesting, AI-powered analysis, and paper trading.",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#050505",
  "theme_color": "#050505",
  "orientation": "portrait",
  "prefer_related_applications": false,
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "categories": ["finance", "productivity", "utilities", "business"],

  "icons": [
    { "src": "/icon-48.png",   "sizes": "48x48",     "type": "image/png", "purpose": "any" },
    { "src": "/icon-72.png",   "sizes": "72x72",     "type": "image/png", "purpose": "any" },
    { "src": "/icon-96.png",   "sizes": "96x96",     "type": "image/png", "purpose": "any" },
    { "src": "/icon-128.png",  "sizes": "128x128",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-144.png",  "sizes": "144x144",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-152.png",  "sizes": "152x152",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "maskable" },
    { "src": "/icon-256.png",  "sizes": "256x256",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-384.png",  "sizes": "384x384",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "maskable" },
    { "src": "/icon-1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any" }
  ],

  "screenshots": [
    {
      "src": "/opengraph.jpg",
      "sizes": "1200x630",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Trade Lab — Live chart with indicators, paper trading panel and AI tools"
    },
    {
      "src": "/screenshot-narrow.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Trade Lab — Mobile trading dashboard with live market data"
    }
  ],

  "shortcuts": [
    {
      "name": "Live Chart",
      "short_name": "Chart",
      "description": "View live market charts and drawing tools",
      "url": "/chart",
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Backtests",
      "short_name": "Backtests",
      "description": "Run and review strategy backtests",
      "url": "/backtests",
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "AI Assistant",
      "short_name": "AI",
      "description": "Get AI-powered trading insights",
      "url": "/ai",
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Community",
      "short_name": "Community",
      "description": "Browse and share trading ideas",
      "url": "/community",
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],

  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "protocol_handlers": [
    {
      "protocol": "web+tradelab",
      "url": "/?action=%s"
    }
  ],

  "file_handlers": [
    {
      "action": "/backtests",
      "accept": {
        "text/csv": [".csv"]
      },
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }],
      "launch_type": "single-client"
    },
    {
      "action": "/strategies",
      "accept": {
        "application/json": [".json"]
      },
      "icons": [{ "src": "/icon-96.png", "sizes": "96x96", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.tradelab.app",
      "id": "com.tradelab.app"
    },
    {
      "platform": "webapp",
      "url": "https://tradelab.replit.app/manifest.json"
    }
  ],

  "widgets": [
    {
      "name": "Trade Lab Markets",
      "short_name": "Markets",
      "description": "Quick view of market prices and your latest backtest results",
      "tag": "markets-widget",
      "template": "generic-medium",
      "ms_ac_template": "/widgets/market-widget.json",
      "data": "/api/klines?symbol=BTCUSDT&interval=1d&limit=1",
      "type": "application/json",
      "auth": false,
      "update": 3600,
      "screenshots": [
        {
          "src": "/icon-512.png",
          "sizes": "512x512",
          "label": "Trade Lab Markets Widget"
        }
      ],
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }],
      "backgrounds": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
  ],

  "scope_extensions": [
    { "origin": "https://tradelab.replit.app" },
    { "origin": "https://*.replit.app" },
    { "origin": "https://*.replit.dev" }
  ],

  "edge_side_panel": {
    "preferred_width": 400
  },

  "note_taking": {
    "new_note_url": "/journal"
  }
}
