{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "/icon-96.png",
                  "width": "32px",
                  "height": "32px",
                  "style": "person"
                }
              ],
              "verticalContentAlignment": "center"
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Trade Lab",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Light"
                },
                {
                  "type": "TextBlock",
                  "text": "Markets",
                  "spacing": "None",
                  "size": "Small",
                  "color": "Light",
                  "isSubtle": true
                }
              ],
              "verticalContentAlignment": "center"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "BTC/USDT",
                  "weight": "Bolder",
                  "size": "Default"
                },
                {
                  "type": "TextBlock",
                  "text": "${if(count(body), body[0].close, 'N/A')}",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "bottom",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "24h",
                  "size": "Small",
                  "color": "Accent",
                  "isSubtle": true
                }
              ]
            }
          ]
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "High",
                  "size": "Small",
                  "isSubtle": true
                },
                {
                  "type": "TextBlock",
                  "text": "${if(count(body), body[0].high, '--')}",
                  "weight": "Bolder",
                  "size": "Small",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Low",
                  "size": "Small",
                  "isSubtle": true
                },
                {
                  "type": "TextBlock",
                  "text": "${if(count(body), body[0].low, '--')}",
                  "weight": "Bolder",
                  "size": "Small",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Volume",
                  "size": "Small",
                  "isSubtle": true
                },
                {
                  "type": "TextBlock",
                  "text": "${if(count(body), body[0].volume, '--')}",
                  "weight": "Bolder",
                  "size": "Small",
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open Trade Lab",
      "url": "/chart"
    }
  ]
}
