{
  "buildCommand": "pnpm --filter @workspace/trade-backtest run build",
  "outputDirectory": "artifacts/trade-backtest/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_BASE_URL": "@vite_api_base_url"
  }
}
