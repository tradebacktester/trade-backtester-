{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter @workspace/db run push-force && pnpm --filter @workspace/api-server run build"
  },
  "deploy": {
    "startCommand": "SERVE_FRONTEND=false node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
